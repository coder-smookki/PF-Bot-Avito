# Database (PM2 / нативный Postgres: localhost; опционально: docker compose -f docker-compose.deps.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=pfavito
DB_PASSWORD=pfavito_secret
DB_DATABASE=pfavito

# JWT
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRATION=7d

# Telegram Bot (опционально; поднимайте bot отдельно при наличии каталога bot/)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot/webhook
API_URL=http://localhost:3000/api
ADMIN_IDS=

# T-Bank (Tinkoff) API
TBANK_TERMINAL_KEY=your-terminal-key
TBANK_PASSWORD=your-terminal-password
TBANK_API_URL=https://securepay.tinkoff.ru/v2

# Server
SERVER_PORT=3000
SERVER_URL=http://localhost:3000
# Опционально: через запятую для CORS
# CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Client
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Admin (Vite — задайте перед npm run build в admin/)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
VITE_API_URL=http://localhost:3000/api

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
